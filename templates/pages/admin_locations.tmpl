{{define "title"}}Gestionar Ubicaciones{{end}}

{{define "main"}}
{{with .SimpleList}}
<div class="mx-auto max-w-2xl p-4 bg-background min-h-screen">
  <div class="mb-6">
    <div class="flex justify-between items-center mb-4">
      <h1 class="text-3xl font-bold text-foreground">Gestionar Ubicaciones</h1>
      <a href="/dashboard/locations/new" class="inline-flex items-center gap-2 rounded-md border border-border px-4 py-2 text-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer">
        {{icon "plus" "h-4 w-4"}}
        Agregar
      </a>
    </div>
    <p class="text-muted-foreground mb-4">
      {{.Total}} {{if eq .Total 1}}ubicación{{else}}ubicaciones{{end}} en total
    </p>
    {{template "simple_filters" dict "Action" "/dashboard/locations" "Search" .Search "Sort" .Sort "HasFilters" .HasFilters "Placeholder" "Buscar por nombre..."}}
  </div>

  <div class="bg-card rounded-lg shadow-sm p-6">
    <table class="w-full caption-bottom text-sm">
      <thead class="[&_tr]:border-b">
        <tr class="border-b">
          <th class="h-10 px-2 text-left align-middle font-black">Nombre</th>
          <th class="h-10 px-2 text-left align-middle font-black">Número de Libros</th>
          <th class="h-10 px-2 text-right align-middle font-black">Acciones</th>
        </tr>
      </thead>
      <tbody class="[&_tr:last-child]:border-0">
        {{if not .Locations}}
        <tr class="border-b"><td colspan="3" class="p-2 align-middle text-center">No se encontraron ubicaciones</td></tr>
        {{end}}
        {{range .Locations}}
        <tr class="border-b transition-colors hover:bg-muted/50">
          <td class="p-2 align-middle">
            <a href="/dashboard/books?locationSlug={{.Slug}}" class="font-medium text-sm underline hover:decoration-indigo-500 transition-colors cursor-pointer">{{.Name}}</a>
          </td>
          <td class="p-2 align-middle">{{.BookCount}}</td>
          <td class="p-2 align-middle text-right">
            <a href="/dashboard/locations/{{.ID}}" class="inline-flex items-center rounded-md border border-border px-3 py-1.5 text-xs hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer">Editar</a>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}
{{end}}

{{define "title"}}{{.BookDetail.Book.Title}}{{end}}

{{define "main"}}
{{with .BookDetail}}
{{$curID := .Book.ID}}
{{$neighbors := .Neighbors}}
<div class="mx-auto max-w-3xl p-4 bg-background min-h-screen">
  <div class="mb-6 flex items-center justify-between">
    <a href="/books" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
      {{icon "arrow-left" "h-4 w-4"}}
      Volver a la biblioteca
    </a>
    {{if $.IsAuthenticated}}
    <a href="/dashboard/books/{{.Book.ID}}" class="inline-flex items-center gap-2 rounded-md border border-border px-4 py-2 text-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer">
      {{icon "pencil" "h-4 w-4"}}
      Editar
    </a>
    {{end}}
  </div>

  {{with .Book}}
  <div class="rounded-lg border border-border bg-card text-card-foreground shadow-sm mb-6">
    <div class="p-6">
      <h1 class="flex items-start gap-3 text-2xl font-semibold">
        {{icon "book-open" "h-6 w-6 mt-1 shrink-0"}}
        <span>{{.Title}}</span>
      </h1>
    </div>

    <div class="p-6 pt-0 space-y-5">
      <div class="flex items-start gap-3">
        {{icon "user" "h-5 w-5 mt-0.5 text-muted-foreground shrink-0"}}
        <div>
          <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Autor(es)</p>
          <p class="text-base">
            {{if .Author1Slug}}
            <a href="/books?authorSlug={{.Author1Slug}}" class="underline hover:decoration-indigo-500">{{.Author1Display}}</a>
            {{else}}{{.Author1Display}}{{end}}
            {{if .Author2LastName}}
            &nbsp;·&nbsp;
            {{if .Author2Slug}}
            <a href="/books?authorSlug={{.Author2Slug}}" class="underline hover:decoration-indigo-500">{{.Author2Display}}</a>
            {{else}}{{.Author2Display}}{{end}}
            {{end}}
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        {{icon "library-big" "h-5 w-5 mt-0.5 text-muted-foreground shrink-0"}}
        <div>
          <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Editorial</p>
          <p class="text-base">
            {{if .PublisherSlug}}
            <a href="/books?publisherSlug={{.PublisherSlug}}" class="underline hover:decoration-indigo-500">{{deref .PublisherName}}</a>
            {{else}}{{deref .PublisherName}}{{end}}
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        {{icon "layout-list" "h-5 w-5 mt-0.5 text-muted-foreground shrink-0"}}
        <div>
          <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Categoría</p>
          <p class="text-base">
            {{if .CategorySlug}}
            <a href="/books?categorySlug={{.CategorySlug}}" class="underline hover:decoration-indigo-500">{{deref .CategoryName}}</a>
            {{else}}{{deref .CategoryName}}{{end}}
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        {{icon "map-pin" "h-5 w-5 mt-0.5 text-muted-foreground shrink-0"}}
        <div>
          <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Ubicación</p>
          <p class="text-base">
            {{if .LocationSlug}}
            <a href="/books?locationSlug={{.LocationSlug}}" class="underline hover:decoration-indigo-500">{{if .LocationName}}{{deref .LocationName}}{{else}}Sin ubicación{{end}}</a>
            {{else}}{{if .LocationName}}{{deref .LocationName}}{{else}}Sin ubicación{{end}}{{end}}
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        {{icon "book-open" "h-5 w-5 mt-0.5 text-muted-foreground shrink-0"}}
        <div>
          <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">ISBN</p>
          <p class="text-base font-mono">{{if .ISBN}}{{deref .ISBN}}{{else}}-{{end}}</p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        {{icon "scan-line" "h-5 w-5 mt-0.5 text-muted-foreground shrink-0"}}
        <div>
          <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Escaneado?</p>
          <p class="text-base inline-flex items-center gap-2">
            {{template "scandot" .Scanned}}
            {{if eq .Scanned "done"}}Escaneado{{else if eq .Scanned "pending"}}Pendiente{{else}}No aplica{{end}}
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        {{icon "calendar" "h-5 w-5 mt-0.5 text-muted-foreground shrink-0"}}
        <div>
          <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide">Agregado</p>
          <p class="text-base">{{longDate .CreatedAt}}</p>
        </div>
      </div>
    </div>
  </div>
  {{end}}

  <!-- Ubicación en la biblioteca física -->
  {{if gt (len $neighbors) 1}}
  <div class="mt-6 rounded-lg border border-border bg-card text-card-foreground shadow-sm">
    <div class="p-6 pb-3">
      <h2 class="flex items-center gap-2 text-lg font-semibold">
        {{icon "map-pin" "h-5 w-5 text-primary"}}
        Ubicación en biblioteca
      </h2>
      <p class="text-sm text-muted-foreground mt-1">
        Libros contiguos en <span class="font-medium">{{if .Book.LocationName}}{{deref .Book.LocationName}}{{else}}sin ubicación{{end}}</span>,
        categoría <span class="font-medium">{{deref .Book.CategoryName}}</span>, en orden de estante.
      </p>
    </div>
    <div class="px-6 pb-6 overflow-x-auto">
      <table class="w-full caption-bottom text-sm">
        <tbody>
          {{range $neighbors}}
          {{if eq .ID $curID}}
          <tr class="border-y-2 border-primary bg-primary/10">
            <td class="p-3 align-middle w-8 text-center">{{icon "map-pin" "h-4 w-4 text-primary inline"}}</td>
            <td class="p-3 align-middle">
              <div class="font-bold text-primary">{{.Title}}</div>
              <div class="text-xs text-muted-foreground">{{.Author1Display}}</div>
            </td>
            <td class="p-3 align-middle text-right whitespace-nowrap">
              <span class="inline-flex items-center rounded-full bg-primary px-2.5 py-0.5 text-xs font-medium text-primary-foreground">Este libro</span>
            </td>
          </tr>
          {{else}}
          <tr class="border-b last:border-0 hover:bg-muted/50 transition-colors">
            <td class="p-3 align-middle w-8"></td>
            <td class="p-3 align-middle">
              <a href="/books/{{.ID}}" class="font-medium underline hover:decoration-indigo-500 transition-colors">{{.Title}}</a>
              <div class="text-xs text-muted-foreground">{{.Author1Display}}</div>
            </td>
            <td class="p-3 align-middle text-right whitespace-nowrap">
              {{template "scandot" .Scanned}}
            </td>
          </tr>
          {{end}}
          {{end}}
        </tbody>
      </table>
    </div>
  </div>
  {{end}}

</div>
{{end}}
{{end}}

{{define "title"}}Dashboard{{end}}

{{define "main"}}
{{with .Home}}
<div class="mx-auto max-w-7xl p-4">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-foreground">Dashboard</h1>
      <p class="text-muted-foreground mt-2">Panel de administración de la biblioteca</p>
    </div>
    <a href="/dashboard/books/new" class="inline-flex items-center gap-2 rounded-md border border-border px-4 py-2 text-sm hover:bg-accent hover:text-accent-foreground transition-colors cursor-pointer">
      {{icon "square-plus" "h-4 w-4"}}
      Agregar libro
    </a>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    {{template "statcard" dict "Href" "/dashboard/books" "Title" "Total Libros" "Value" .TotalBooks "Icon" "book-open" "Color" "text-blue-600" "Desc" "volúmenes únicos"}}
    {{template "statcard" dict "Href" "/dashboard/authors" "Title" "Autores" "Value" .TotalAuthors "Icon" "users" "Color" "text-green-600" "Desc" (printf "%s libros/autor" .AvgBooksPerAuthor)}}
    {{template "statcard" dict "Href" "/dashboard/publishers" "Title" "Editoriales" "Value" .TotalPublishers "Icon" "library-big" "Color" "text-purple-600" "Desc" (printf "%s libros/editorial" .AvgBooksPerPublisher)}}
    {{template "statcard" dict "Href" "/dashboard/locations" "Title" "Categorías" "Value" .TotalCategories "Icon" "layout-list" "Color" "text-orange-600" "Desc" "temas diversos"}}
  </div>

  <!-- Adquisiciones recientes -->
  <div class="rounded-lg border border-border bg-card text-card-foreground shadow-sm">
    <div class="p-6">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-semibold flex items-center gap-2">
          {{icon "calendar" "h-6 w-6 text-primary"}}
          Adquisiciones Recientes
        </h2>
        <a href="/dashboard/books" class="inline-flex items-center gap-2 rounded-md border border-border px-3 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground transition-colors">
          Gestionar libros
          {{icon "arrow-right" "h-4 w-4"}}
        </a>
      </div>
    </div>
    <div class="p-6 pt-0">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {{range .RecentBooks}}
        <a href="/dashboard/books/{{.ID}}" class="group p-4 rounded-lg border border-border hover:bg-accent/50 transition-colors block">
          <div class="space-y-3">
            <div class="flex items-start gap-2">
              {{icon "book" "h-4 w-4 text-primary mt-0.5 flex-shrink-0"}}
              <h3 class="font-semibold text-sm line-clamp-2 group-hover:text-primary transition-colors">{{.Title}}</h3>
            </div>
            <div class="text-xs text-muted-foreground space-y-1">
              <div class="flex items-center gap-1">
                {{icon "users" "h-3 w-3 flex-shrink-0"}}
                <span class="font-medium truncate">{{.Author1Display}}</span>
              </div>
              <div class="flex items-center gap-1">
                {{icon "library-big" "h-3 w-3 flex-shrink-0"}}
                <span class="truncate">{{deref .PublisherName}}</span>
              </div>
            </div>
          </div>
        </a>
        {{end}}
      </div>
    </div>
  </div>
</div>
{{end}}
{{end}}

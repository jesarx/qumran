{{define "statcard"}}
<a href="{{.Href}}" class="block">
  <div class="rounded-lg border border-border bg-card text-card-foreground shadow-sm hover:shadow-lg transition-all duration-200 cursor-pointer group relative overflow-hidden">
    <div class="flex flex-row items-center justify-between space-y-0 p-6 pb-2 relative z-10">
      <h3 class="text-sm font-medium text-muted-foreground">{{.Title}}</h3>
      {{icon .Icon (printf "h-5 w-5 %s" .Color)}}
    </div>
    <div class="p-6 pt-0 relative z-10">
      <div class="text-3xl font-bold text-foreground">{{.Value}}</div>
      <p class="text-xs text-muted-foreground mt-1">{{.Desc}}</p>
      <div class="flex items-center gap-1 mt-2">
        <span class="text-xs {{.Color}} font-medium">Explorar</span>
        {{icon "arrow-right" (printf "h-3 w-3 %s group-hover:translate-x-1 transition-transform" .Color)}}
      </div>
    </div>
  </div>
</a>
{{end}}
